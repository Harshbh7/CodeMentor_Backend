# ==============================================================
# CodeMentor AI - Environment Variables
# Copy this file to .env and fill in real values
# NEVER commit .env to version control
# ==============================================================

# --------------------------------------------------------------
# Application Settings
# --------------------------------------------------------------
APP_NAME="CodeMentor AI"
APP_VERSION="1.0.0"
APP_ENV="development"          # development | staging | production
DEBUG=true
API_PREFIX="/api/v1"

# --------------------------------------------------------------
# Server Settings
# --------------------------------------------------------------
HOST="0.0.0.0"
PORT=8000
WORKERS=1                      # Increase in production

# --------------------------------------------------------------
# PostgreSQL Database
# --------------------------------------------------------------
POSTGRES_USER=codementor_user
POSTGRES_PASSWORD=codementor_pass
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=codementor_db

# Computed by the app automatically — do not set manually here
# DATABASE_URL=postgresql+asyncpg://user:pass@host:port/db

# --------------------------------------------------------------
# JWT Authentication
# --------------------------------------------------------------
JWT_SECRET_KEY=your-super-secret-jwt-key-change-this-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# --------------------------------------------------------------
# Google Gemini API
# --------------------------------------------------------------
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-1.5-pro
GEMINI_EMBEDDING_MODEL=models/text-embedding-004

# --------------------------------------------------------------
# ChromaDB Vector Database
# --------------------------------------------------------------
CHROMA_HOST=localhost
CHROMA_PORT=8001
CHROMA_PERSIST_DIR=./chroma_data

# --------------------------------------------------------------
# Redis (Optional - for caching & session management)
# --------------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# --------------------------------------------------------------
# File Upload Settings
# --------------------------------------------------------------
MAX_UPLOAD_SIZE_MB=50
UPLOAD_DIR=./uploads

# --------------------------------------------------------------
# Logging
# --------------------------------------------------------------
LOG_LEVEL=INFO                 # DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_FORMAT=json                # json | text
